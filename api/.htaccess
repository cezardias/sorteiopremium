<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # Redirecionar HTTP para HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Proteção de diretórios: Aponta tudo para a pasta public/
  RewriteCond %{REQUEST_URI} !^/public/ 
  RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Bloquear acesso a arquivos sensíveis no nível de diretório
<FilesMatch "^\.env|composer\.json|composer\.lock|package\.json|package-lock\.json|artisan$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Security Headers (Back-up para o Middleware)
<IfModule mod_headers.c>
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>
